# Public Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase secret
SUPABASE_SECRET_KEY=

# Preview generation (server only)
GEMINI_API_KEY=

# Local generation on the production PC (optional)
# STORY_TEXT_PROVIDER=ollama makes all story text run through this machine.
# Keep STORY_IMAGE_PROVIDER=gemini until ComfyUI has been installed and its
# approved workflow is configured. Never expose either local service publicly.
STORY_TEXT_PROVIDER=gemini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
STORY_IMAGE_PROVIDER=gemini
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Stripe (server only except the publishable key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRON_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
